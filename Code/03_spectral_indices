library(terra)
library(imageRy)
library(viridis)

#listing files:
im.list()
#file: matogrosso_l5_1992219_lrg.jpg ---> l5 è un satellite del programma landsat 5
#importing data
mato1992 <- im.import("matogrosso_l5_1992219_lrg.jpg")
#nb: il nord  e il sud sono invertiti --> uso flip
mato1992 <- flip(mato1992)
#l1=nir, l2=red, l3=green --> metto l'infrarosso nel rosso
im.plotRGB(mato1992, r=1,g=2, b=3)   #gran parte del papesaggio occupato da foresta (in rosso)
#l'acqua assorbe tutto l'infrarosso, quindi risulterebbe nera, ma essendo che sotto c'è il suolo viene riflesso da esso.
im.plotRGB(mato1992, r=2,g=1, b=3)   #infrarosso nel verde
im.plotRGB(mato1992, r=2,g=3, b=1)   #infrarosso nel blu, per auemntare la percezione del suolo nudo (in giallo)

